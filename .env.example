# Required Discord application settings.
DISCORD_TOKEN=replace-with-your-discord-bot-token
CLIENT_ID=replace-with-your-discord-application-client-id
GUILD_ID=replace-with-your-test-guild-id

# Server-specific access settings.
# Use comma-separated IDs when more than one user or role should be allowed.
TRAINER_ROLE_ID=replace-with-your-trainer-role-id
ADMIN_USER_IDS=replace-with-your-discord-user-id
ADMIN_ROLE_IDS=replace-with-your-admin-role-id

# Optional local bot diagnostics.
AEGIS_BOT_DEBUG_SERVER_ENABLED=1
AEGIS_BOT_DEBUG_PORT=8788

# Optional benchmark worker settings.
BENCHMARK_WORKER_MODE=mock
BENCHMARK_WORKER_URL=http://127.0.0.1:8787
BENCHMARK_WORKER_HOST=127.0.0.1
BENCHMARK_WORKER_PORT=8787
BENCHMARK_WORKER_TIMEOUT_MS=15000
BENCHMARK_SHOWDOWN_FORMAT=gen9benchmarkdoublesag

# Optional PostgreSQL settings.
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=professor_aegis
PGUSER=professor_aegis
PGPASSWORD=replace-with-local-database-password
PGSSLMODE=disable
